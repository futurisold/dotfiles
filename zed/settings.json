// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diff_view_style": "unified",
  "project_panel": {
    "hide_gitignore": false
  },
  "debugger": {
    "dock": "bottom"
  },
  "icon_theme": "Zed (Default)",
  "show_edit_predictions": true,
  "edit_predictions": {
      "provider": "copilot",
      "disabled_globs": [],
      "mode": "eager",
      "enabled_in_text_threads": true
  },
  "terminal": {
      "keep_selection_on_copy": true
  },
  "agent": {
    "inline_assistant_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-6-thinking-latest"
    },
    "default_profile": "write",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-6-thinking-latest"
    },
    "model_parameters": [],
    "profiles": {
      "write": {
        "name": "Write",
        "tools": {
          "fetch": false
        }
      }
    }
  },
  "file_scan_inclusions": [
      ".codex/*",
      ".claude/*"
  ],
  // AMPs
  "agent_servers": {
      "claude": {
      "default_model": "opus"
    },
  },
  // MCPs
  "context_servers": {
    "deepwiki": {
      "command": "uv",
      "args": ["run", "--project", "****/mcp-servers", "mcp-deepwiki"],
      "env": { "SYMAI_WARNINGS": "0" }
    },
    "oracle": {
      "command": "uv",
      "args": ["run", "--project", "****/mcp-servers", "mcp-oracle"],
      "env": { "SYMAI_WARNINGS": "0" }
    },
    "mermaid": {
      "command": "uv",
      "args": ["run", "--project", "****/mcp-servers", "mcp-mermaid"],
      "env": { "SYMAI_WARNINGS": "0" }
    },
    "scrape": {
      "command": "uv",
      "args": ["run", "--project", "****/mcp-servers", "mcp-scrape"],
      "env": { "SYMAI_WARNINGS": "0" }
    },
    "search": {
      "command": "uv",
      "args": ["run", "--project", "****/mcp-servers", "mcp-search"],
      "env": {
        "SYMAI_WARNINGS": "0",
        "EAI_API_BASE": "****",
        "EAI_API_KEY": "****"
      }
    },
    "librarian": {
      "command": "uv",
      "args": ["run", "--project", "****/mcp-servers", "mcp-librarian"],
      "env": { "SYMAI_WARNINGS": "0" }
    }
  },
  "ssh_connections": [
    {
      "host": "extensity",
      "projects": [
        {
          "paths": ["~/dev"]
        }
      ]
    }
  ],
  "ui_font_size": 13,
  "ui_font_family": "Berkeley Mono",
  "buffer_font_size": 14,
  "buffer_font_family": "Berkeley Mono",
  "buffer_font_weight": 500,
  "theme": "Gruvbox Dark Hard",
  "experimental.theme_overrides": {
    "syntax": {
      "comment": { "font_style": "italic" },
      "comment.doc": { "font_style": "italic" }
    }
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "on_yank"
  },
  "format_on_save": "off",
  "enable_language_server": true,
  "tab_size": 4,
  "relative_line_numbers": "enabled",
  "languages": {
    "Ruby": {
      "language_servers": ["!solargraph"]
    },
    "Python": {
      "show_edit_predictions": true,
      "enable_language_server": true,
      "format_on_save": "on",
      "language_servers": ["!ty", "ruff", "basedpyright", "!pyrefly", "!pyright", "!pylsp"]
    },
    "JSON": {
      "format_on_save": "on",
      "show_edit_predictions": true
    },
    "LaTeX": {
      "format_on_save": "on",
      "show_edit_predictions": true
    }
  },
  "lsp": {
    "basedpyright": {
      "settings": {
        "basedpyright.disableTaggedHints": true,
        "basedpyright.analysis": {
          "extraPaths": ["****/symbolicai"],
          "diagnosticMode": "workspace",
          "typeCheckingMode": "off"
        }
      }
    },
    "texlab": {
      "settings": {
        "texlab": {
          "build": {
            "executable": "pdflatex",
            "args": ["-synctex=1", "-interaction=nonstopmode", "%f"],
            "onSave": true,
            "forwardSearchAfter": true
          },
          "forwardSearch": {
            "executable": "zathura",
            "args": [
              "--synctex-forward",
              "%l:1:%f",
              "-x",
              "zed %%{input}:%%{line}",
              "%p"
            ]
          }
        }
      }
    }
  },
  "use_autoclose": true,
  "show_completions_on_input": true,
  "show_completion_documentation": true,
  "scroll_beyond_last_line": "off",
  "current_line_highlight": "line",
  "hard_tabs": false,
  "scrollbar": {
    "show": "never"
  },
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,
  "inlay_hints": {
    "enabled": false
  },
  "soft_wrap": "editor_width"
}
